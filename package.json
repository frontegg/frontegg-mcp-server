{
  "name": "@frontegg/frontegg-mcp-server",
  "version": "2.0.0",
  "description": "Frontegg MCP server — 96 tools across two surfaces: mobile-SDK audit/fix (analyze, diff, configure) and Frontegg Management API (roles, permissions, users, tenants, applications, integrations). Companion to the coding-agent skills at github.com/frontegg/coding-agent-skills.",
  "main": "dist/index.js",
  "bin": {
    "frontegg-mcp-server": "./dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frontegg/frontegg-mcp-server.git"
  },
  "homepage": "https://github.com/frontegg/coding-agent-toolkit",
  "bugs": "https://github.com/frontegg/frontegg-mcp-server/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rimraf dist",
    "test": "npm run test:jest && npm run test:vitest",
    "test:jest": "jest",
    "test:vitest": "vitest run",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test:e2e": "tsx scripts/test-e2e.ts",
    "test:e2e:demos": "tsx scripts/test-e2e.ts demos",
    "test:e2e:ground": "tsx scripts/test-e2e.ts ground",
    "test:e2e:break": "tsx scripts/test-e2e.ts break",
    "test:e2e:stdio": "tsx scripts/test-e2e.ts stdio",
    "test:e2e:apply": "tsx scripts/test-e2e.ts apply",
    "demo:rn": "tsx src/demo.ts rn",
    "demo:flutter": "tsx src/demo.ts flutter",
    "demo:ionic": "tsx src/demo.ts ionic",
    "demo:security": "tsx src/demo.ts security",
    "demo:ios": "tsx src/demo.ts ios",
    "demo:android": "tsx src/demo.ts android",
    "demos:build": "vhs docs/demos/tapes/rn.tape && vhs docs/demos/tapes/flutter.tape && vhs docs/demos/tapes/ionic.tape && vhs docs/demos/tapes/security.tape"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "frontegg",
    "ciam",
    "authentication",
    "oauth",
    "passkeys",
    "rbac",
    "claude",
    "cursor",
    "ai",
    "agent",
    "ios",
    "android",
    "flutter",
    "react-native",
    "ionic"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "ignore": "^5.3.1",
    "node-cache": "^5.1.2",
    "p-retry": "^6.2.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "ts-jest": "^29.1.5",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
