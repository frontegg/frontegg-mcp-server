# VHS tape — Flutter SDK version drift demo
# Regenerate with: vhs docs/demos/tapes/flutter.tape
Output docs/demos/demo-flutter.gif

Set Shell "bash"
Set FontSize 14
Set Width 1100
Set Height 560
Set Padding 24
Set Theme "Dracula"
Set TypingSpeed 35ms

Type "npm run demo:flutter"
Sleep 400ms
Enter
Sleep 10s
