# VHS tape — Security sweep demo
# Regenerate with: vhs docs/demos/tapes/security.tape
Output docs/demos/demo-security.gif

Set Shell "bash"
Set FontSize 14
Set Width 1100
Set Height 640
Set Padding 24
Set Theme "Dracula"
Set TypingSpeed 35ms

Type "npm run demo:security"
Sleep 400ms
Enter
Sleep 10s
